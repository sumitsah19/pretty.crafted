# Copy to backend/.env for local development. Every variable here is read by
# application.properties (spring.config.import picks up .env automatically).

# ── Database (MySQL) ──────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3307/prettycrafted?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&sessionVariables=sql_mode=NO_ENGINE_SUBSTITUTION
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# Schema management: local dev uses Hibernate auto-migration; production must
# use DDL_AUTO=validate with FLYWAY_ENABLED=true (see application-prod.properties).
DDL_AUTO=update
FLYWAY_ENABLED=false

# ── JWT ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64  (min 32 bytes — enforced at startup)
JWT_SECRET=replace_with_strong_random_secret_min_32_chars
JWT_EXPIRATION_MS=86400000

# ── CORS ─────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Auth cookie ───────────────────────────────────────────────────
# false for local HTTP development; must be true in production (HTTPS)
COOKIE_SECURE=false

# ── Seed admin ────────────────────────────────────────────────────
# Password for the fallback admin account created on first startup
# (admin@prettycrafted.local). Optional: SEED_ADMIN_EMAIL promotes existing
# Google-login accounts to ADMIN (comma-separated).
SEED_ADMIN_PASSWORD=choose_a_strong_admin_password
# SEED_ADMIN_EMAIL=you@example.com

# ── Google OAuth2 (customer + admin sign-in) ─────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ── MSG91 phone OTP ──────────────────────────────────────────────
# Secret AuthKey from the MSG91 dashboard. Used ONLY server-side to verify the
# widget access token. NEVER expose this in the frontend. Blank = OTP disabled.
MSG91_AUTH_KEY=your_msg91_auth_key

# ── Razorpay (payments) ──────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
# From Razorpay Dashboard → Webhooks → Secret; webhooks are rejected without it
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Resend (transactional email — HTTP API, not SMTP) ────────────
# Blank key = dev mode: emails are logged to the console, never sent.
RESEND_API_KEY=
MAIL_FROM=support@prettycrafted.com

# ── Cloudinary (product / return-evidence image uploads) ─────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Sentry (optional; blank = disabled) ──────────────────────────
SENTRY_DSN=

# ── URLs / misc ──────────────────────────────────────────────────
PORT=8080
FRONTEND_URL=http://localhost:5173
# Backend's own public URL — distinct from FRONTEND_URL, used for links to
# backend-only routes (e.g. the email unsubscribe link).
API_URL=http://localhost:8080
SWAGGER_ENABLED=true
# Enables dev-only endpoints under /api/dev/** (e.g. the email-test ping).
# Requires the "local" Spring profile too — never set this outside local dev.
DEV_TOOLS_ENABLED=false
