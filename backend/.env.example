# ── Database ──────────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/prettycrafted?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# ── JWT ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_strong_random_secret_min_32_chars
JWT_EXPIRATION_MS=86400000

# ── CORS ─────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Auth Cookie ───────────────────────────────────────────────────
# Set to false for local HTTP development, true in production (HTTPS)
COOKIE_SECURE=false

# ── Google OAuth2 ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ── Razorpay ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── MSG91 Phone OTP ──────────────────────────────────────────────
# Secret AuthKey from MSG91 dashboard. Used ONLY server-side to verify the
# widget access token. NEVER expose this in the frontend. Blank = OTP disabled.
MSG91_AUTH_KEY=your_msg91_auth_key

# ── Email (SMTP) ─────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=noreply@prettycrafted.in

# ── Sentry (optional) ────────────────────────────────────────────
SENTRY_DSN=https://your_key@sentry.io/your_project_id

# ── Other ────────────────────────────────────────────────────────
PORT=8080
FRONTEND_URL=http://localhost:5173
SWAGGER_ENABLED=true
FLYWAY_ENABLED=false
UPLOAD_DIR=uploads
