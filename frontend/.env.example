# ── API ───────────────────────────────────────────────────────────
# Development: /api  (proxied to http://localhost:8080 by Vite)
# Production : https://your-api-domain.com/api
VITE_API_BASE_URL=/api

# ── App ──────────────────────────────────────────────────────────
VITE_APP_TITLE=Pretty.Crafted

# ── Google OAuth2 ────────────────────────────────────────────────
# Same client ID used in backend — get from console.cloud.google.com
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
