# ── API ───────────────────────────────────────────────────────────
# Development: /api  (proxied to http://localhost:8080 by Vite)
# Production : https://your-api-domain.com/api
VITE_API_BASE_URL=/api

# ── App ──────────────────────────────────────────────────────────
VITE_APP_TITLE=Pretty.Crafted

# Razorpay public key id only. Never put RAZORPAY_KEY_SECRET in frontend env.
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# ── Google OAuth2 ────────────────────────────────────────────────
# Same client ID used in backend — get from console.cloud.google.com
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ── MSG91 Phone OTP (Web SDK, custom UI) ─────────────────────────
# Widget ID + Token Auth are public, widget-scoped values (safe in frontend).
# The secret AuthKey is backend-only (MSG91_AUTH_KEY) — never put it here.
# Leave VITE_MSG91_TOKEN_AUTH blank to hide the "Continue with Mobile" button.
VITE_MSG91_WIDGET_ID=36666d6e7743373331303331
VITE_MSG91_TOKEN_AUTH=your_msg91_widget_token_auth

# ── Sentry (Crash Monitoring) ─────────────────────────────────────
# Get DSN from https://sentry.io — leave blank to disable in dev
VITE_SENTRY_DSN=

# ── PostHog (Analytics) ───────────────────────────────────────────
# Get key from https://app.posthog.com — leave blank to disable
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
